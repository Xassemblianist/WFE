# WFE GCP dağıtım ayarları — kopyala: cp config.env.example config.env, doldur.
PROJECT_ID=your-gcp-project
BUCKET=your-wfe-bucket
ZONE=europe-west4-a          # Hollanda (Türkiye'ye yakın, GPU mevcut)
GPU_TYPE=nvidia-tesla-t4     # ucuz; L4/A100 daha hızlı
MACHINE=n1-standard-8
REPO=https://github.com/Xassemblianist/WFE.git
CUDA_ARCH=75                 # T4=75, L4=89, A100=80
